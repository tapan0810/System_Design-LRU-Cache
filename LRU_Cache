    void put(int key, int value) { //O(1)
       if(map[key] != m.end()){
        Node* oldNode = m[key];
        delNode(oldNode);
        m.erase(oldNode);
       } 

       if(m.size() == limit){
        //delete LRU
        m.erase(tail -> prev ->key);
        delNode(tail->prev);
       }

       Node* newNode = new Node(key,val);
       addNode(newNode);
       m[key] = newNode;
    }
};

